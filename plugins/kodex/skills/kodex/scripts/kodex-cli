#!/usr/bin/env bash
# If executed by a non-bash shell, re-exec with bash.
if [ -z "${BASH_VERSION:-}" ] && [ -f "$0" ]; then
  exec bash "$0" "$@"
fi
set -euo pipefail

EXPECTED_VERSION="1.3.0"
REPO="nguyenyou/kodex"

# Expected SHA-256 checksums for each artifact (updated each release alongside EXPECTED_VERSION)
CHECKSUM_kodex_macos_arm64="ac96c6d2104c60b84b598bad98169d2fb2c34f267dcb520d73bda01b1b078c83"
CHECKSUM_kodex_macos_x64="2c013c3b300174a42229c3783a748a25e97cf6280420ecbc763f1c544c021c99"
CHECKSUM_kodex_linux_x64="f6208b140c38c5395c740e734cbba956aac306549ff7fce74b99201591576b92"

# Cache location: follow XDG spec
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/kodex"

# Detect platform → artifact name
OS=$(uname -s); ARCH=$(uname -m)
case "$OS-$ARCH" in
  Darwin-arm64)  ARTIFACT="kodex-macos-arm64" ;;
  Darwin-x86_64) ARTIFACT="kodex-macos-x64" ;;
  Linux-x86_64)  ARTIFACT="kodex-linux-x64" ;;
  *) echo "kodex: unsupported platform $OS-$ARCH" >&2; exit 1 ;;
esac

# Binary path includes version
BINARY="$CACHE_DIR/$EXPECTED_VERSION-$ARTIFACT"

# Fast path: binary exists, non-empty, executable → exec immediately
if [ -s "$BINARY" ] && [ -x "$BINARY" ]; then
  exec "$BINARY" "$@"
fi

# Download
echo "kodex: downloading v${EXPECTED_VERSION} for ${OS}-${ARCH}..." >&2
mkdir -p "$CACHE_DIR"
TMP=$(mktemp "$CACHE_DIR/kodex-temp.XXXXXX")
trap 'rm -f "$TMP"' EXIT

BASE_URL="https://github.com/${REPO}/releases/download/v${EXPECTED_VERSION}"

curl -f -L -o "$TMP" "${BASE_URL}/${ARTIFACT}" || {
  echo "kodex: download failed. Visit https://github.com/${REPO}/releases" >&2
  exit 1
}

# Verify checksum
CHECKSUM_VAR="CHECKSUM_${ARTIFACT//-/_}"
EXPECTED_HASH="${!CHECKSUM_VAR}"
if [ -n "$EXPECTED_HASH" ]; then
  ACTUAL_HASH=$(shasum -a 256 "$TMP" | awk '{print $1}')
  if [ "$ACTUAL_HASH" != "$EXPECTED_HASH" ]; then
    echo "kodex: checksum verification FAILED" >&2
    echo "  expected: $EXPECTED_HASH" >&2
    echo "  actual:   $ACTUAL_HASH" >&2
    echo "  The downloaded binary may have been tampered with." >&2
    exit 1
  fi
fi

# Install atomically
chmod +x "$TMP"
mv "$TMP" "$BINARY"
trap - EXIT

# macOS: remove quarantine
[ "$OS" = "Darwin" ] && xattr -d com.apple.quarantine "$BINARY" 2>/dev/null || true

echo "kodex: installed v${EXPECTED_VERSION}" >&2
exec "$BINARY" "$@"
